{
  "ci": {
    "collect": {
      "url": ["$BASE_URL"],
      "numberOfRuns": 3
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.50 }],
        "categories:seo": ["error", { "minScore": 0.90 }],
        "categories:best-practices": ["error", { "minScore": 0.80 }],
        "categories:accessibility": ["warn", { "minScore": 0.40 }],
        "categories:pwa": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
