{
  "buildCommand": "node scripts/inject-seo.js",
  "outputDirectory": ".",
  "framework": null,
  "headers": [
    {
      "source": "/(.*\\.(?:png|jpg|jpeg|webp|mp3|ogg|ttf|woff2))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*\\.(?:html|json))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
